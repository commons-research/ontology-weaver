@prefix : <https://w3id.org/emi#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.wikidata.org/entity/Q16521> rdfs:subClassOf :Taxon .

<https://w3id.org/emi> vann:preferredNamespaceUri : .

:Aliquot a owl:Class ;
    rdfs:label "Aliquot" ;
    rdfs:comment "A sample taken from an extract sample for chemical analysis or other treatment." ;
    rdfs:subClassOf sosa:Sample .

:BioAssayResults a owl:Class ;
    rdfs:label "Bioassay result" ;
    rdfs:comment "An object to store bioactivity results." .

:BioassayAnalysis a owl:Class ;
    rdfs:label "Bioassay analysis" ;
    rdfs:comment "A bioassay is an analytical method to determine the concentration or potency of a substance by its effect on living animals or plants (in vivo), or on living cells or tissues(in vitro)." ;
    rdfs:isDefinedBy "https://en.wikipedia.org/wiki/Bioassay" ;
    rdfs:subClassOf :Analysis .

:Blank a owl:Class ;
    rdfs:label "Blank sample" ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
:VGF138_A12 rdf:type emi:Blank ;
            dcterms:identifier "VGF138_A12" .""" ;
    rdfs:comment "A blank sample." ;
    rdfs:subClassOf sosa:Sample .

:CSpair a owl:Class ;
    rdfs:label "GNPS consensus spectra pair" ;
    rdfs:comment "A pair of 2 GNPSConsensusSpectra." ;
    rdfs:subClassOf :SpectralPair .

:ComputationalAnalysis a owl:Class ;
    rdfs:label "Computational analysis" ;
    rdfs:comment "A data analysis made with computational resources (e.g., computers, software tools)." ;
    rdfs:subClassOf :Analysis .

:ContinousTrait a owl:Class ;
    rdfs:label "Continuous trait" ;
    rdfs:comment "A specific quantitative characteristic of an individual such as height and blood pressure." ;
    rdfs:subClassOf :Trait .

:DiscreteTrait a owl:Class ;
    rdfs:label "Discrete trait" ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
:flower-color rdf:value  red ;
              qudt:hasUnit unit:X .""" ;
    rdfs:comment "A discrete trait structured value. When applicable, value units should be defined as the QUDT Units Vocabulary terms." ;
    rdfs:subClassOf :Trait .

:ExtractSample a owl:Class ;
    rdfs:label "Extract sample" ;
    rdfs:comment "A natural extract obtained from the processing of a RawMaterial." ;
    rdfs:subClassOf sosa:Sample .

:FBMNComponent a owl:Class ;
    rdfs:label "FBMN component" ;
    rdfs:comment "Feature-based molecular network component." .

:InteractionType a owl:Class ;
    rdfs:label "Interaction type" ;
    vann:example """@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
:INTERACTION-1 a emi:Interaction ;
    emi:isClassifiedWith obo:RO_0002557 . #has pathogen
obo:RO_0002557 a emi:InteractionType .""" ;
    rdfs:comment "It represents the kind of interaction between a source and a target organism sample in an interaction system (e.g., has pathogen and allelopath of). We recommed using RO vocabulary terms." .

:LCMSAnalysisNeg a owl:Class ;
    rdfs:label "Negative LCMS analysis" ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
:VGF138_A02_neg.mzXML rdf:type emi:LCMSAnalysisNeg .""" ;
    rdfs:comment "An LCMS analysis in negative ionization mode (pos or neg)." ;
    rdfs:subClassOf :LCMSAnalysis ;
    :hasIonization "negative" .

:LCMSAnalysisPos a owl:Class ;
    rdfs:label "Positive LCMS analysis" ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
:VGF138_A02_pos.mzXML rdf:type emi:LCMSAnalysisPos .""" ;
    rdfs:comment "An LCMS analysis in positive ionization mode (positive or negative)." ;
    rdfs:subClassOf :LCMSAnalysis ;
    :hasIonization "positive" .

:Locality a owl:Class .

:NonTrait a owl:Class ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
:EXAMPLE-NON-TRAIT rdf:type emi:NonTrait ;
    rdf:value  12.4""" ;
    rdfs:comment "A non trait structured value. When applicable, value units should be defined as QUDT Units Vocabulary terms." ;
    rdfs:subClassOf sosa:Result .

:QCSample a owl:Class ;
    rdfs:label "Quality control sample" ;
    rdfs:comment "A quality control (QC) sample." ;
    rdfs:subClassOf sosa:Sample .

:RawMaterial a owl:Class ;
    rdfs:label "Raw material" ;
    rdfs:comment "A raw laboratory biological material, i.e., before extraction." ;
    rdfs:subClassOf sosa:Sample .

:WDChemicalStructure a owl:Class ;
    rdfs:label "Wikidata chemical" ;
    rdfs:comment "A Wikidata chemical entry." ;
    rdfs:subClassOf :Chemical .

:componentLink a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "component link" ;
    rdfs:domain :GNPSConsensusSpectrum ;
    rdfs:range xsd:anyURI .

:hasAdduct a owl:DatatypeProperty ;
    rdfs:label "has adduct" ;
    rdfs:domain :StructuralAnnotation ;
    rdfs:range xsd:string .

:hasAnatomicalEntity a owl:ObjectProperty ;
    rdfs:label "has anatomical entity"@en ;
    rdfs:comment "It can be used to assign an anatomical entity (e.g., body parts) to a source and/or target organism sample in an interaction system such as GloBI. When applicable, we recommend to state UBERON vocabulary anatomical entity terms." ;
    rdfs:domain sosa:Sample ;
    rdfs:range :AnatomicalEntity .

:hasAnnotation a owl:ObjectProperty ;
    rdfs:label "has annotation" ;
    rdfs:domain :MS2Spectrum ;
    rdfs:range :SpectrumAnnotation .

:hasClass a owl:ObjectProperty ;
    rdfs:label "has class" ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
@prefix npc: <https://w3id.org/emi/npc#> .
:CANOPUS-mzspec%3AMSV000087728%3AVGF147_E06_features_ms2_neg.mgf%3Ascan%3A45 rdf:type emi:ChemicalTaxonAnnotation ;
            emi:hasClass "npc:CADINANE_SESQUITERPENOIDS" .""" ;
    rdfs:domain [ ] ;
    rdfs:range <https://w3id.org/emi/npc#Class> ;
    rdfs:subPropertyOf :isClassifiedWith ;
    owl:propertyDisjointWith :hasSuperClass .

:hasClassProbability a owl:DatatypeProperty ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
:CANOPUS-mzspec%3AMSV000087728%3AVGF147_E06_features_ms2_neg.mgf%3Ascan%3A45 rdf:type emi:ChemicalTaxonAnnotation ;
            emi:hasClassProbability "0.6451306343078613"^^xsd:double .""" ;
    rdfs:domain :ChemicalTaxonAnnotation ;
    rdfs:range xsd:double ;
    rdfs:subPropertyOf :hasProbability .

:hasConsensusSpectrum a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has consensus spectrum" ;
    rdfs:domain :LCMSFeature ;
    rdfs:range :GNPSConsensusSpectrum ;
    rdfs:subPropertyOf :hasSpectrum .

:hasConsistencyScore a owl:DatatypeProperty ;
    rdfs:label "has consistency score" ;
    rdfs:comment "An ISDB score." ;
    rdfs:domain :StructuralAnnotation ;
    rdfs:range xsd:integer ;
    rdfs:subPropertyOf :hasScore .

:hasCosine a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has cosine" ;
    rdfs:domain :SpectralPair ;
    rdfs:range xsd:double .

:hasCosmicScore a owl:DatatypeProperty ;
    rdfs:label "has cosmic score" ;
    rdfs:domain :StructuralAnnotation ;
    rdfs:range xsd:double ;
    rdfs:subPropertyOf :hasScore .

:hasDevelopmentalStage a owl:ObjectProperty ;
    rdfs:label "has developmental stage" ;
    rdfs:comment "The source or target organism sample of an interaction system such as GloBI can have a developmental stage." ;
    rdfs:domain sosa:Sample ;
    rdfs:range :DevelopmentalStage .

:hasFBMNComponent a owl:ObjectProperty ;
    rdfs:label "has FBMN component" ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
@prefix usi: <https://metabolomics-usi.ucsd.edu/dashinterface/?usi1=> .
usi:mzspec%3AMSV000087728%3AVGF153_A02_features_ms2_neg.mgf%3Ascan%3A356 rdf:type emi:LCMSFeature ;
            emi:hasFBMNComponent :VGF153_A02_fbmn_neg_componentindex_0 .""" ;
    rdfs:comment "Feature-based molecular network component." ;
    rdfs:domain :LCMSFeature .

:hasFeatureArea a owl:DatatypeProperty ;
    rdfs:label "has feature area" ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
@prefix usi: <https://metabolomics-usi.ucsd.edu/dashinterface/?usi1=> .
usi:mzspec%3AMSV000087728%3AVGF153_A02_features_ms2_neg.mgf%3Ascan%3A356 rdf:type emi:LCMSFeature ;
            emi:hasFeatureArea "1180836.665658199"^^xsd:double .""" ;
    rdfs:comment "Assign a feature area to a MS2 spectrum." ;
    rdfs:range xsd:double .

:hasFinalScore a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has final score" ;
    rdfs:comment "An ISDB score." ;
    rdfs:domain :StructuralAnnotation ;
    rdfs:range xsd:double ;
    rdfs:subPropertyOf :hasScore .

:hasFirstMember a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has first member" ;
    rdfs:comment "The first member of a spectral pair." ;
    rdfs:domain :LFpair ;
    rdfs:range :LCMSFeature ;
    rdfs:subPropertyOf :hasPairMember .

:hasGNPSLCMSLink a owl:DatatypeProperty ;
    rdfs:label "has GNPS LCMS link" ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
@prefix : <https://w3id.org/emi/abox#> .
@prefix usi: <https://metabolomics-usi.ucsd.edu/dashinterface/?usi1=> .
:VGF138_A02_neg.mzXML rdf:type emi:LCMSAnalysis ;
            emi:hasGNPSLCMSLink "https://dashboard.gnps2.org/?usi=mzspec%3AMSV000087728%3AVGF138_A02_neg.mzXML"^^xsd:anyURI .""" ;
    rdfs:comment "It relates  GNPS LCMS link to a LCMS Analysis." ;
    rdfs:domain :LCMSAnalysis ;
    rdfs:range xsd:anyURI .

:hasHabitat a owl:ObjectProperty ;
    rdfs:label "has habitat" ;
    rdfs:comment "It can be used to assign a habitat to an interaction system such as from GloBI. When applicable, we recommend to state ENVO or CMECS vocabulary terms." ;
    rdfs:domain :Interaction ;
    rdfs:range :Habitat .

:hasInChIKey a owl:ObjectProperty ;
    rdfs:label "has InChIKey" ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
@prefix wd: <http://www.wikidata.org/entity/> .
wd:Q27145340 rdf:type emi:Chemical ;
            dcterms:identifier "Q27145340" ;
            emi:hasInChIKey :ZCCLDKGWJIREQF-PDBXOOCHSA-N .""" ;
    rdfs:comment "It can be used to assign an InChIKey either to a chemical or to an spectrum annotation." ;
    rdfs:domain [ ] ;
    rdfs:range :InChIKey ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    owl:inverseOf :isInChIKeyOf ;
    owl:propertyChainAxiom [ rdf:first :hasChemicalStructure ] .

:hasInChIKey2D a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has InChIKey2D" ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
@prefix wd: <http://www.wikidata.org/entity/> .
:ZCCLDKGWJIREQF-PDBXOOCHSA-N  rdf:type emi:InChIKey ;
            emi:hasInChIKey2D :ZCCLDKGWJIREQF .""" ;
    rdfs:comment "It can be used to represent the InChIKey2D of an emi:InChIKey that is chemical structure." ;
    rdfs:domain :InChIKey ;
    rdfs:range :InChIKey2D ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    owl:inverseOf :isInChIKey2DOf .

:hasIonization a owl:AnnotationProperty,
        owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:domain <http://org.semanticweb.owlapi/error#Error1> ;
    rdfs:range xsd:string .

:hasLCMSFeature a owl:ObjectProperty ;
    rdfs:label "has LCMS feature" ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
@prefix : <https://w3id.org/emi/abox#> .
@prefix usi: <https://metabolomics-usi.ucsd.edu/dashinterface/?usi1=> .
:VGF153_A02_lcms_feature_list_neg rdf:type emi:LCMSFeatureSet ;
            emi:hasLCMSFeature usi:mzspec%3AMSV000087728%3AVGF153_A02_features_ms2_neg.mgf%3Ascan%3A1 .""" ;
    rdfs:comment "It relates a LCMS feature set to a feature." ;
    rdfs:domain :LCMSFeatureSet ;
    rdfs:range :LCMSFeature ;
    rdfs:subPropertyOf :hasSpectrum .

:hasLCMSFeatureSet a owl:ObjectProperty ;
    rdfs:label "has LCMS feature set" ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
:VGF138_A02_neg.mzXML rdf:type emi:LCMSAnalysis ;
            emi:hasLCMSFeatureSet :VGF153_A02_lcms_feature_list_neg .""" ;
    rdfs:comment "It relates a LCMS analysis to a set of features." ;
    rdfs:domain :LCMSAnalysis ;
    rdfs:range :LCMSFeatureSet ;
    rdfs:subPropertyOf sosa:hasResult .

:hasMassDifference a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has Mass difference" ;
    rdfs:domain :SpectralPair ;
    rdfs:range xsd:double .

:hasMassiveDOI a owl:ObjectProperty ;
    rdfs:label "has Massive DOI." ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
@prefix : <https://w3id.org/emi/abox#> .
@prefix usi: <https://metabolomics-usi.ucsd.edu/dashinterface/?usi1=> .
:VGF138_A02_neg.mzXML rdf:type emi:LCMSAnalysis ;
            emi:hasMassiveDOI <https://massive.ucsd.edu/ProteoSAFe/dataset.jsp?accession=MSV000087728> .""" ;
    rdfs:comment "It assigns a Massive repository DOI to a LCMS Analysis." ;
    rdfs:domain :LCMSAnalysis .

:hasParentMass a owl:DatatypeProperty ;
    rdfs:label "has parent mass" ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
@prefix usi: <https://metabolomics-usi.ucsd.edu/dashinterface/?usi1=> .
usi:mzspec%3AMSV000087728%3AVGF153_A02_features_ms2_neg.mgf%3Ascan%3A356 rdf:type emi:LCMSFeature ;
            emi:hasParentMass "833.447509765625"^^xsd:double .""" ;
    rdfs:comment "The parent mass of a LCMS feature." ;
    rdfs:domain :LCMSFeature ;
    rdfs:range xsd:double .

:hasPathway a owl:ObjectProperty ;
    rdfs:label "has pathway" ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
@prefix : <https://w3id.org/emi/abox#> .
@prefix npc: <https://w3id.org/emi/npc#> .
:CANOPUS-mzspec%3AMSV000087728%3AVGF147_E06_features_ms2_neg.mgf%3Ascan%3A45 rdf:type emi:ChemicalTaxonAnnotation ;
            emi:hasPathway npc:TERPENOIDS .""" ;
    rdfs:domain [ ] ;
    rdfs:range <https://w3id.org/emi/npc#Pathway> ;
    rdfs:subPropertyOf :isClassifiedWith .

:hasPathwayProbability a owl:DatatypeProperty ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
:CANOPUS-mzspec%3AMSV000087728%3AVGF147_E06_features_ms2_neg.mgf%3Ascan%3A45 rdf:type emi:ChemicalTaxonAnnotation ;
            emi:hasPathwayProbability "0.5601769685745239"^^xsd:double .""" ;
    rdfs:domain :ChemicalTaxonAnnotation ;
    rdfs:range xsd:double ;
    rdfs:subPropertyOf :hasProbability .

:hasPhysiologicalStage a owl:ObjectProperty ;
    rdfs:label "has physiological stage" ;
    rdfs:comment "It can be used to assign a physiological stage to a source and/or target organism sample in an interaction system such as GloBI. When applicable, we recommend to state PATO vocabulary anatomical entity terms." ;
    rdfs:domain sosa:Sample ;
    rdfs:range :PhysiologicalStage .

:hasRawSpectrum a owl:DatatypeProperty ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
@prefix usi: <https://metabolomics-usi.ucsd.edu/dashinterface/?usi1=> .
usi:mzspec%3AMSV000087728%3AVGF153_A02_features_ms2_neg.mgf%3Ascan%3A356 rdf:type emi:LCMSFeature ;
            emi:hasRawSpectrum "((58.7747, 0.034375), (107.3847, 0.0453125), (177.2855, 0.0375), (185.9186, 0.0375), (243.0295, 0.484375), (257.0457, 0.21875), (270.0167, 0.0765625), (271.0244, 0.4375), (285.0398, 0.359375), (300.028, 0.15625), (313.0341, 0.171875), (314.0425, 1.0), (315.0507, 0.640625), (551.4942, 0.0453125), (619.0516, 0.0375), (675.5888, 0.0421875))" .""" ;
    rdfs:comment "The raw spectrum of a LCMS individual MS2 spectrum. Its value is a tuple of binary tuples (see vann:example)." ;
    rdfs:domain :LCMSFeature ;
    rdfs:range xsd:string .

:hasRelativeFeatureArea a owl:DatatypeProperty ;
    rdfs:label "has relative feature area" ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
@prefix usi: <https://metabolomics-usi.ucsd.edu/dashinterface/?usi1=> .
usi:mzspec%3AMSV000087728%3AVGF153_A02_features_ms2_neg.mgf%3Ascan%3A356 rdf:type emi:LCMSFeature ;
            emi:hasRelativeFeatureArea "0.0004294112935902454"^^xsd:double .""" ;
    rdfs:comment "The relative feature area of a LCMS individual MS2 spectrum." ;
    rdfs:domain :LCMSFeature ;
    rdfs:range xsd:double .

:hasRetentionTime a owl:DatatypeProperty ;
    rdfs:label "has retention time" ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
@prefix usi: <https://metabolomics-usi.ucsd.edu/dashinterface/?usi1=> .
usi:mzspec%3AMSV000087728%3AVGF153_A02_features_ms2_neg.mgf%3Ascan%3A356 rdf:type emi:LCMSFeature ;
            emi:hasRetentionTime "7.663716666666667"^^xsd:double .""" ;
    rdfs:comment "The retention time of a LCMS individual MS2 spectrum." ;
    rdfs:domain :LCMSFeature ;
    rdfs:range xsd:double .

:hasRowId a owl:DatatypeProperty ;
    rdfs:label "has row id" ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
@prefix usi: <https://metabolomics-usi.ucsd.edu/dashinterface/?usi1=> .
usi:mzspec%3AMSV000087728%3AVGF153_A02_features_ms2_neg.mgf%3Ascan%3A356 rdf:type emi:LCMSFeature ;
            emi:hasRowId "356"^^xsd:integer .""" ;
    rdfs:comment "The row id of a LCMS individual MS2 spectrum." ;
    rdfs:domain :LCMSFeature ;
    rdfs:range xsd:integer .

:hasSMILES a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has SMILES" ;
    rdfs:comment "The simplified molecular-input line-entry system (SMILES) is a specification in the form of a line notation for describing the structure of chemical species using short ASCII strings." ;
    rdfs:domain :ChemicalStructure ;
    rdfs:range xsd:string .

:hasSecondMember a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has second member" ;
    rdfs:comment "The second member of a spectral pair." ;
    rdfs:domain :LFpair ;
    rdfs:range :LCMSFeature ;
    rdfs:subPropertyOf :hasPairMember .

:hasSex a owl:ObjectProperty ;
    rdfs:label "has sex" ;
    rdfs:comment "It can be used to assign a biological sex to a source and/or target organism sample in an interaction system such as GloBI. When applicable, we recommend to state PATO vocabulary biological sex terms." ;
    rdfs:domain [ ] ;
    rdfs:range :BiologicalSex .

:hasSource a owl:ObjectProperty ;
    rdfs:label "has source" ;
    rdfs:comment "An interaction system has a source sample that interacts with a target one. emi:hasSource should state the origin of an interaction." ;
    rdfs:domain :Interaction ;
    rdfs:range sosa:Sample .

:hasSpec2VecDoc a owl:ObjectProperty ;
    rdfs:label "has spec2vec documentation" ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
@prefix : <https://w3id.org/emi/abox#> .
@prefix usi: <https://metabolomics-usi.ucsd.edu/dashinterface/?usi1=> .
usi:mzspec%3AMSV000087728%3AVGF153_A02_features_ms2_neg.mgf%3Ascan%3A356 rdf:type emi:LCMSFeature ;
            emi:hasSpec2VecDoc :spec2vec_doc_mzspec%3AMSV000087728%3AVGF153_A02_features_ms2_neg.mgf%3Ascan%3A356 .""" ;
    rdfs:domain :LCMSFeature ;
    rdfs:range :Spec2VecDoc ;
    rdfs:subPropertyOf owl:topObjectProperty .

:hasSpec2VecLoss a owl:DatatypeProperty ;
    rdfs:label "has spec2vec loss" ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
@prefix : <https://w3id.org/emi/abox#> .
:spec2vec_doc_mzspec%3AMSV000087728%3AVGF153_A02_features_ms2_neg.mgf%3Ascan%3A356 rdf:type emi:Spec2VecDoc ;
            emi:hasSpec2VecLoss "157.86"^^xsd:double .""" ;
    rdfs:comment "The Spec2Vec losses of a Spec2Vec document." ;
    rdfs:domain :Spec2VecDoc ;
    rdfs:range xsd:double ;
    rdfs:subPropertyOf :hasSpec2VecValue .

:hasSpec2VecPeak a owl:DatatypeProperty ;
    rdfs:label "has spec2vec peak" ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
@prefix : <https://w3id.org/emi/abox#> .
:spec2vec_doc_mzspec%3AMSV000087728%3AVGF153_A02_features_ms2_neg.mgf%3Ascan%3A356 rdf:type emi:Spec2VecDoc ;
            emi:hasSpec2VecPeak "271.02"^^xsd:double .""" ;
    rdfs:comment "The Spec2Vec peaks of a Spec2Vec document." ;
    rdfs:domain :Spec2VecDoc ;
    rdfs:range xsd:double ;
    rdfs:subPropertyOf :hasSpec2VecValue .

:hasSpectralScore a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has spectral score" ;
    rdfs:comment "An ISDB score." ;
    rdfs:domain :StructuralAnnotation ;
    rdfs:range xsd:double ;
    rdfs:subPropertyOf :hasScore .

:hasSuperClassProbability a owl:DatatypeProperty ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
:CANOPUS-mzspec%3AMSV000087728%3AVGF147_E06_features_ms2_neg.mgf%3Ascan%3A45 rdf:type emi:ChemicalTaxonAnnotation ;
            emi:hasSuperClassProbability "0.34501510858535767"^^xsd:double .""" ;
    rdfs:domain :ChemicalTaxonAnnotation ;
    rdfs:range xsd:double ;
    rdfs:subPropertyOf :hasProbability .

:hasTarget a owl:ObjectProperty ;
    rdfs:label "has target" ;
    rdfs:comment "An interaction system has a source sample that interacts with a target one. emi:hasTarget should state the target of an interaction." ;
    rdfs:domain :Interaction ;
    rdfs:range sosa:Sample .

:hasTaxoScore a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has taxo score" ;
    rdfs:comment "An ISDB score." ;
    rdfs:domain :StructuralAnnotation ;
    rdfs:range xsd:integer ;
    rdfs:subPropertyOf :hasScore .

:hasUSI a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has universal spectrum identifier" ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
@prefix usi: <https://metabolomics-usi.ucsd.edu/dashinterface/?usi1=> .
usi:mzspec%3AMSV000087728%3AVGF153_A02_features_ms2_neg.mgf%3Ascan%3A356 rdf:type emi:LCMSFeature ;
            emi:hasUSI "mzspec:MSV000087728:VGF153_A02_features_ms2_neg.mgf:scan:356" .""" ;
    rdfs:comment "The universal spectrum identifier provided by GNPS." ;
    rdfs:domain [ ] ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf owl:topDataProperty .

:hasZodiacScore a owl:DatatypeProperty ;
    rdfs:label "has zodiac score" ;
    rdfs:domain :StructuralAnnotation ;
    rdfs:range xsd:double ;
    rdfs:subPropertyOf :hasScore .

:inTaxon a owl:ObjectProperty ;
    rdfs:label "found in taxon" ;
    rdfs:domain [ ] ;
    rdfs:range [ ] .

:scientificName a owl:DatatypeProperty ;
    rdfs:label "scientific name" ;
    rdfs:domain :Taxon ;
    rdfs:range xsd:string .

:spectrumLink a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "spectrum link" ;
    rdfs:domain :GNPSConsensusSpectrum ;
    rdfs:range xsd:anyURI .

:AnatomicalEntity a owl:Class,
        owl:NamedIndividual ;
    rdfs:label "Anatomical entity"@en ;
    rdfs:comment "An anatomical entity can be an organism part (e.g. brain, blood, liver and so on) or a material anatomical entity such as a cell." ;
    skos:closeMatch <http://purl.org/genex#AnatomicalEntity> .

:BiologicalSex a owl:Class,
        owl:NamedIndividual ;
    rdfs:label "biological sex"@en ;
    rdfs:comment "An organismal quality inhering in a bearer by virtue of the bearer's ability to undergo sexual reproduction in order to differentiate the individuals or types involved [source: http://purl.obolibrary.org/obo/PATO_0000047]. We recommend to use PATO ontology terms for inviduals of this class." ;
    skos:closeMatch <http://purl.obolibrary.org/obo/PATO_0000047> .

:DevelopmentalStage a owl:Class,
        owl:NamedIndividual ;
    rdfs:label "Developmental stage" ;
    rdfs:comment "A developmental stage is spatiotemporal region encompassing some part of the life cycle of an organism, e.g., blastula stage. We recommend to use the developmental stage terms from UBERON of a source or target organism sample in an interaction system such as from GloBI." ;
    skos:closeMatch <http://www.ebi.ac.uk/efo/EFO_0000399> .

:Habitat a owl:Class ;
    rdfs:label "Habitat" ;
    rdfs:comment "It defines an environment where an emi:Interaction occurs. If applicable, we recommend to use the habitat terms from ENVO or CMECS of an interaction system such as from GloBI." .

:InformationSource a owl:Class ;
    rdfs:label "Information source" ;
    rdfs:comment "The source of information. For example, the source of a given annotation that might be a bioinformatics database or machine learning classification model." ;
    skos:note """This can be replaced by or related with the provenance ontology (W3C recommendation).
https://www.w3.org/TR/prov-o/""" .

:OrganismGroup a owl:Class ;
    rdfs:label "Group of organisms" ;
    rdfs:comment "A group of organisms (see emi:Organism). These organims may be grouped by biological sex (emi:BiologicalSex), for example." ;
    skos:altLabel "Cluster of organisms",
        "Organism cluster",
        "Organism group" .

:PhysiologicalStage a owl:Class ;
    rdfs:label "Physiological stage" ;
    rdfs:comment "A physiological stage is a specific phase or condition of an organism in its life cycle (e.g., viability stage). If applicable, we recommend to use the physiological stage terms from PATO of a source or target organism sample in an interaction system such as from GloBI." .

:System a owl:Class ;
    rdfs:label "System" ;
    rdfs:comment "Any part of the observable universe. A system is often composed of subsystems, for example, the Earth system contains a biome that contains a population that contains organisms that contains organs and so on." .

:hasSuperClass a owl:ObjectProperty ;
    rdfs:label "has super class" ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
@prefix : <https://w3id.org/emi/abox#> .
@prefix npc: <https://w3id.org/emi/npc#> .
:CANOPUS-mzspec%3AMSV000087728%3AVGF147_E06_features_ms2_neg.mgf%3Ascan%3A45 rdf:type emi:ChemicalTaxonAnnotation ;
            emi:hasSuperClass npc:SESQUITERPENOIDS .""" ;
    rdfs:domain [ ] ;
    rdfs:range <https://w3id.org/emi/npc#Superclass> ;
    rdfs:subPropertyOf :isClassifiedWith .

:inChIKey a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "InChIKey value" ;
    rdfs:comment "The InChIKey data value, that is a textual representation of chemical structures. This value is composed of 27 characters and it is a condensed digital representation of the InChI." ;
    rdfs:domain :InChIKey ;
    rdfs:range xsd:string .

:inChIKey2D a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "InChIKey 2D value" ;
    rdfs:comment "The InChIKey 2D data value, that is a textual representation of chemical structures. This value is composed of the first 14 characters of its corresponding InChIKey of 27 character fixed length." ;
    rdfs:domain :InChIKey2D ;
    rdfs:range xsd:string .

:isInChIKeyOf a owl:ObjectProperty ;
    rdfs:label "is InChIKey of" ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
@prefix wd: <http://www.wikidata.org/entity/> .
@prefix dcterms: < http://purl.org/dc/terms/> .
wd:Q27145340 rdf:type emi:Chemical ;
             dcterms:identifier "Q27145340" .
 :ZCCLDKGWJIREQF-PDBXOOCHSA-N  emi:isInChIKeyOf wd:Q27145340 . """ ;
    rdfs:domain :InChIKey ;
    rdfs:range [ ] .

<https://w3id.org/emi/npc#Class> rdfs:subClassOf :ChemicalTaxon .

<https://w3id.org/emi/npc#Pathway> rdfs:subClassOf :ChemicalTaxon .

<https://w3id.org/emi/npc#Superclass> rdfs:subClassOf :ChemicalTaxon .

:LCMSFeatureSet a owl:Class ;
    rdfs:label "LCMS feature set" ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
:VGF153_A02_lcms_feature_list_neg rdf:type emi:LCMSFeatureSet .""" ;
    rdfs:comment "A set of Liquid chromatography–mass spectrometry (LCMS) features obtained from the processing of a given LCMS analysis." .

:LFpair a owl:Class ;
    rdfs:label "LCMS feature pair" ;
    rdfs:comment "A pair of LCMSFeature." ;
    rdfs:subClassOf :SpectralPair .

:Organism a owl:Class ;
    rdfs:label "Organism" ;
    rdfs:comment "A living being, such as an animal, a plant, a bacterium, or a fungus., Any individual living (or previously living) being. Example: animal, human being. An organism is associated to a taxon such as \"Homo Sapiens\", NCBI taxonomy identifier: 9606." ;
    rdfs:seeAlso <http://purl.org/net/orth#Organism> ;
    rdfs:subClassOf :System ;
    skos:altLabel "Living being" .

:Trait a owl:Class ;
    rdfs:label "Trait" ;
    rdfs:comment "A specific characteristic of an individual. Traits can be determined by genes, environmental factors or by a combination of both. Traits can be discrete (i.e., qualitative such as color) or continuous (quantitative such as height)." ;
    rdfs:subClassOf sosa:Result .

:hasChemicalStructure a owl:ObjectProperty ;
    rdfs:label "has chemical structure representation" ;
    rdfs:comment "Recommendation: prefer the chemical structure representation 2D InChIKey that also represents a collection of InChIKeys (i.e. chemicals) with common attributes. As a result, we can reduce the number of triples and redundacy to represent the same information that are common to many chemicals." ;
    rdfs:domain :StructuralAnnotation ;
    rdfs:range :ChemicalStructure .

:hasPairMember a owl:ObjectProperty ;
    rdfs:label "has pair member" ;
    rdfs:comment "LCMSFeature" ;
    rdfs:domain :SpectralPair ;
    rdfs:range :MS2Spectrum .

:hasSpec2VecValue a owl:DatatypeProperty ;
    rdfs:label "has spec2vec value" ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
@prefix : <https://w3id.org/emi/abox#> .
:spec2vec_doc_mzspec%3AMSV000087728%3AVGF153_A02_features_ms2_neg.mgf%3Ascan%3A356 rdf:type emi:Spec2VecDoc ;
            emi:hasSpec2VecValue "271.02"^^xsd:double .""" ;
    rdfs:comment "A mass spectral similarity scoring through learning of structural relationships. Spec2vec is a novel spectral similarity score inspired by a natural language processing algorithm -- Word2Vec. Where Word2Vec learns relationships between words in sentences, spec2vec does so for mass fragments and neutral losses in MS/MS spectra. The spectral similarity score is based on spectral embeddings learnt from the fragmental relationships within a large set of spectral data. Analysis and benchmarking of mass spectra similarity measures using gnps data set." ;
    rdfs:domain :Spec2VecDoc ;
    rdfs:range xsd:double ;
    rdfs:subPropertyOf :hasScore .

:hasSpectrum a owl:ObjectProperty ;
    rdfs:label "has spectrum" ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
@prefix : <https://w3id.org/emi/abox#> .
@prefix usi: <https://metabolomics-usi.ucsd.edu/dashinterface/?usi1=> .
:VGF153_A02_lcms_feature_list_neg rdf:type emi:LCMSFeatureSet ;
            emi:hasSpectrum usi:mzspec%3AMSV000087728%3AVGF153_A02_features_ms2_neg.mgf%3Ascan%3A1 .""" ;
    rdfs:comment "It assigns a MS2 spectrum to, for instance, a LCMS feature set. The domain is not defined to provide flexibility. For a LCMS feature set prefer to state the  emi:hasLCMSFeature property." ;
    rdfs:range :MS2Spectrum .

:Chemical a owl:Class ;
    rdfs:label "Chemical" ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
@prefix wd: <http://www.wikidata.org/entity/> .
@prefix dcterms: < http://purl.org/dc/terms/> .
wd:Q27145340 rdf:type emi:Chemical ;
            dcterms:identifier "Q27145340" ;
            emi:hasInChIKey :ZCCLDKGWJIREQF-PDBXOOCHSA-N ;
            rdfs:label "ZCCLDKGWJIREQF-PDBXOOCHSA-N" .""" ;
    rdfs:comment "A chemical. Recommendation: the instances of this class are ideally Wikidata chemical entries. If it is not a Wikidata entry we recommend to be as much as possible consistent in the whole dataset. Metadata can also be provided in order to describe the provenance of the instance (a chemical), for example, by stating the property prov-o:wasDerivedFrom (PROV-Ontology)." ;
    rdfs:subClassOf :ChemicalEntity .

:ChemicalEntity a owl:Class ;
    rdfs:label "Chemical entity" ;
    rdfs:comment "A chemical entity (chemical structure or class)." .

:ChemicalTaxon a owl:Class ;
    rdfs:label "Chemical taxon" ;
    rdfs:comment "As a taxonomy for chemicals such as natural products, we recommend to use the taxonomy derived from NPClassifier (i.e., https://w3id.org/emi/npc)." ;
    rdfs:subClassOf :ChemicalEntity .

:GNPSConsensusSpectrum a owl:Class ;
    rdfs:label "GNPS consensus MS2 spectrum" ;
    rdfs:comment "An MS2 spectrum corresponding to the GNPS consensus spectrum of 1 or more LCMSFeature. Recommendation: instances of this class are ideally built as follows: \"https://metabolomics-usi.ucsd.edu/dashinterface/?usi1={id}\", e.g.: \"https://metabolomics-usi.ucsd.edu/dashinterface/?usi1=mzspec:MassIVE:TASK-773effaad17c4124b9ea9004eaa3f526-spectra/specs_ms.mgf:scan:1028\"." ;
    rdfs:subClassOf :MS2Spectrum .

:Interaction a owl:Class ;
    rdfs:label "Interaction System" ;
    rdfs:comment "An interaction record listed (e.g.,in GloBI database) between Source and Target samples." ;
    rdfs:subClassOf prov:Activity .

:Taxon a owl:Class ;
    rdfs:label "Organism taxon" ;
    rdfs:comment "Organism taxon. In the context of open research data, we recommend the use of Wikidata taxonomy as the classification and nomenclature for all of the organisms." .

:hasProbability a owl:DatatypeProperty ;
    rdfs:label "has probability" ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
:CANOPUS-mzspec%3AMSV000087728%3AVGF147_E06_features_ms2_neg.mgf%3Ascan%3A45 rdf:type emi:ChemicalTaxonAnnotation ;
            emi:hasProbability "0.5601769685745239"^^xsd:double .""" ;
    rdfs:range xsd:double .

:isClassifiedWith a owl:ObjectProperty ;
    rdfs:label "is classified with" ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
@prefix npc: <https://w3id.org/emi/npc#> .
:CANOPUS-mzspec%3AMSV000087728%3AVGF147_E06_features_ms2_neg.mgf%3Ascan%3A45 rdf:type emi:ChemicalTaxonAnnotation ;
            emi:isClassifiedWith npc:CADINANE_SESQUITERPENOIDS .""" ;
    rdfs:comment "It is used to classify any individidual with an external controlled-vocabulary in case rdf:type is not the most suitable solution." .

:isInChIKey2DOf a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "is InChIKey2D of" ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
@prefix wd: <http://www.wikidata.org/entity/> .
:ZCCLDKGWJIREQF-PDBXOOCHSA-N rdf:type emi:InChIKey2D ;
            emi:isInChIKey2DOf :ZCCLDKGWJIREQF ;
            rdfs:label "ZCCLDKGWJIREQF" .
:ZCCLDKGWJIREQF-PDBXOOCHSA-N rdf:type emi:InChIKey. """ ;
    rdfs:comment "It can be used to assign an InChIKey2D to an InChIKey that represents a chemical structure." ;
    rdfs:domain :InChIKey2D ;
    rdfs:range :InChIKey .

:Analysis a owl:Class ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
:VGF138_A02_neg.mzXML rdf:type emi:Analysis .""" ;
    rdfs:comment "Any analysis performed over a sample." ;
    rdfs:subClassOf [ ],
        [ ],
        sosa:Observation .

:InChIKey2D a owl:Class ;
    rdfs:label "2D InChIKey" ;
    rdfs:comment "A collection of chemical structures that share the first 14 characters of their InChIKeys, often returned by mass spectrometry based annotation tools." ;
    rdfs:subClassOf [ owl:onProperty :isInChIKey2DOf ;
            owl:someValuesFrom :InChIKey ],
        [ owl:onProperty :inChIKey2D ],
        :ChemicalStructure .

:LCMSAnalysis a owl:Class ;
    rdfs:label "LCMS analysis" ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
:VGF138_A02_neg.mzXML rdf:type emi:LCMSAnalysis .""" ;
    rdfs:comment "A liquid chromatography–mass spectrometry (LCMS) analysis in a given ionization mode (pos or neg)." ;
    rdfs:subClassOf :Analysis .

:Spec2VecDoc a owl:Class ;
    rdfs:label "Spec2vec document" ;
    rdfs:comment "Document about improved mass spectral similarity scoring through learning of structural relationships. Spec2vec is a novel spectral similarity score inspired by a natural language processing algorithm -- Word2Vec. Where Word2Vec learns relationships between words in sentences, spec2vec does so for mass fragments and neutral losses in MS/MS spectra. The spectral similarity score is based on spectral embeddings learnt from the fragmental relationships within a large set of spectral data. Analysis and benchmarking of mass spectra similarity measures using GNPS data set." .

:SpectralPair a owl:Class ;
    rdfs:label "MS2Spectra pair" ;
    rdfs:comment "A pair of two tandem mass spectrometry (MS2 spectra)." .

:SpectrumAnnotation a owl:Class ;
    rdfs:label "Spectrum annotation" ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
:CANOPUS-mzspec%3AMSV000087728%3AVGF147_E06_features_ms2_neg.mgf%3Ascan%3A45 rdf:type emi:SpectrumAnnotation .""" ;
    rdfs:comment "A spectral annotation." ;
    rdfs:subClassOf [ owl:allValuesFrom :InformationSource ],
        [ owl:allValuesFrom :Analysis ] .

:ChemicalTaxonAnnotation a owl:Class ;
    rdfs:label "Chemical taxon annotation" ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
:CANOPUS-mzspec%3AMSV000087728%3AVGF147_E06_features_ms2_neg.mgf%3Ascan%3A45 rdf:type emi:ChemicalTaxonAnnotation .""" ;
    rdfs:comment "This class is used to annotate a spectrum feature with a chemical taxon. Prefer the Chemical structure annotation class, if the annotation is mainly to assign a chemical representation structure as defined in the emi:ChemicalStructure." ;
    rdfs:subClassOf :SpectrumAnnotation ;
    owl:disjointWith :StructuralAnnotation .

:MS2Spectrum a owl:Class ;
    rdfs:label "MS2 spectrum" ;
    vann:example """@prefix : <https://w3id.org/emi/abox#> .
@prefix emi: <https://w3id.org/emi#> .
@prefix usi: <https://metabolomics-usi.ucsd.edu/dashinterface/?usi1=> .
usi:mzspec%3AMSV000087728%3AVGF153_A02_features_ms2_neg.mgf%3Ascan%3A356 rdf:type emi:MS2Spectrum .""" ;
    rdfs:comment "A fragmentation mass spectrometry (or MS2) spectrum." .

:ChemicalStructure a owl:Class ;
    rdfs:label "Chemical structure representation" ;
    rdfs:comment "A representation of one or more chemical structures. This representation can be defined as molecular information encodings, compact encoding representations, chemical formulas and graphical representations." ;
    rdfs:subClassOf :ChemicalEntity .

:InChIKey a owl:Class ;
    rdfs:label "InChIKey" ;
    rdfs:comment "A chemical structure represented by its InChIKey." ;
    rdfs:subClassOf [ owl:onProperty :inChIKey ],
        :ChemicalStructure .

:hasScore a owl:DatatypeProperty ;
    rdfs:label "has score" ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
@prefix : <https://w3id.org/emi/abox#> .
:spec2vec_doc_mzspec%3AMSV000087728%3AVGF153_A02_features_ms2_neg.mgf%3Ascan%3A356 rdf:type emi:Spec2VecDoc ;
            emi:hasSpec2VecValue "271.02"^^xsd:double .""" ;
    rdfs:domain [ ] .

:LCMSFeature a owl:Class ;
    rdfs:label "LCMS individual MS2 spectrum" ;
    vann:example """@prefix emi: <https://w3id.org/emi#> .
@prefix usi: <https://metabolomics-usi.ucsd.edu/dashinterface/?usi1=> .
usi:mzspec%3AMSV000087728%3AVGF153_A02_features_ms2_neg.mgf%3Ascan%3A356 rdf:type emi:LCMSFeature .""" ;
    rdfs:comment "An LCMS feature from a processed LCMS analysis. Recommendation: instances of this class are ideally built as follows: \"https://metabolomics-usi.ucsd.edu/dashinterface/?usi1={id}\" (e.g., https://metabolomics-usi.ucsd.edu/dashinterface/?usi1=mzspec:MSV000090090:DBGI_01_04_001_features_ms2_pos.mgf:scan:1)." ;
    rdfs:subClassOf :MS2Spectrum .

:StructuralAnnotation a owl:Class ;
    rdfs:label "Chemical structure annotation" ;
    rdfs:comment "This class is used to annotate a spectrum feature with a chemical representation structure as defined in the emi:ChemicalStructure. Prefer the  Chemical taxon annotation class, if the annotation is mainly to assign taxa to a spectrum feature." ;
    rdfs:subClassOf [ owl:onProperty :hasChemicalStructure ;
            owl:someValuesFrom :InChIKey2D ],
        :SpectrumAnnotation .

[] rdf:first :ChemicalStructure .

[] rdf:first :ChemicalTaxonAnnotation .

[] rdf:first :Chemical .

[] rdf:first :SpectrumAnnotation .

[] rdf:first :isInChIKey2DOf .

[] rdf:first :ChemicalStructure .

[] rdf:first :ChemicalTaxonAnnotation .

[] rdf:first :Organism .

[] rdf:first :OrganismGroup .

[] rdf:first :ChemicalStructure .

[] rdf:first :ChemicalTaxonAnnotation .

[] rdf:first :InChIKey .

[] rdf:first :Organism .

[] rdf:first :Taxon .

[] rdf:first :Chemical .

[] rdf:first :SpectrumAnnotation .

[] rdf:first :Spec2VecDoc .

[] rdf:first :StructuralAnnotation .

[] rdf:first :MS2Spectrum .

[] rdf:first :StructuralAnnotation .

