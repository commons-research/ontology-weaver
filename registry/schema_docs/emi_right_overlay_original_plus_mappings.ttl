    dcterms:modified "2012-06-14"^^xsd:date ;
    dcterms:publisher <http://purl.org/dc/aboutdcmi#DCMI> ;
    dcterms:title "DCMI Metadata Terms - other"@en .

<https://w3id.org/emi/npc#SESQUITERPENOIDS> a owl:NamedIndividual,
