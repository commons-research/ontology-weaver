<https://w3id.org/emi/npc#PROLINE_ALKALOIDS> a owl:NamedIndividual,
        <https://w3id.org/emi/npc#Superclass> ;
    rdfs:label "Proline alkaloids" ;
    skos:broader <https://w3id.org/emi/npc#ALKALOIDS> .

<https://w3id.org/emi/npc#TERPHENYLS> a owl:NamedIndividual,
