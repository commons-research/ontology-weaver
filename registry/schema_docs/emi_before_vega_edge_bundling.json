{
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "description": "Ontology hierarchical edge bundling.",
  "padding": 5,
  "width": 720,
  "height": 720,
  "autosize": "none",
  "signals": [
    {
      "name": "tension",
      "value": 0.85,
      "bind": {
        "input": "range",
        "min": 0,
        "max": 1,
        "step": 0.01
      }
    },
    {
      "name": "radius",
      "value": 280,
      "bind": {
        "input": "range",
        "min": 20,
        "max": 400
      }
    },
    {
      "name": "extent",
      "value": 360,
      "bind": {
        "input": "range",
        "min": 0,
        "max": 360,
        "step": 1
      }
    },
    {
      "name": "rotate",
      "value": 0,
      "bind": {
        "input": "range",
        "min": 0,
        "max": 360,
        "step": 1
      }
    },
    {
      "name": "textSize",
      "value": 8,
      "bind": {
        "input": "range",
        "min": 2,
        "max": 20,
        "step": 1
      }
    },
    {
      "name": "textOffset",
      "value": 2,
      "bind": {
        "input": "range",
        "min": 0,
        "max": 10,
        "step": 1
      }
    },
    {
      "name": "layout",
      "value": "cluster",
      "bind": {
        "input": "radio",
        "options": [
          "tidy",
          "cluster"
        ]
      }
    },
    {
      "name": "colorIn",
      "value": "firebrick"
    },
    {
      "name": "colorOut",
      "value": "forestgreen"
    },
    {
      "name": "originX",
      "update": "width / 2"
    },
    {
      "name": "originY",
      "update": "height / 2"
    },
    {
      "name": "active",
      "value": null,
      "on": [
        {
          "events": "text:pointerover",
          "update": "datum.id"
        },
        {
          "events": "pointerover[!event.item]",
          "update": "null"
        }
      ]
    }
  ],
  "data": [
    {
      "name": "tree",
      "values": [
        {
          "id": "root",
          "parent": null,
          "name": "root"
        },
        {
          "id": "https://w3id.org/emi#Aliquot",
          "parent": "root",
          "name": ":Aliquot"
        },
        {
          "id": "https://w3id.org/emi#Analysis",
          "parent": "root",
          "name": ":Analysis"
        },
        {
          "id": "https://w3id.org/emi#AnatomicalEntity",
          "parent": "root",
          "name": ":AnatomicalEntity"
        },
        {
          "id": "https://w3id.org/emi#BioAssayResults",
          "parent": "root",
          "name": ":BioAssayResults"
        },
        {
          "id": "https://w3id.org/emi#BioassayAnalysis",
          "parent": "https://w3id.org/emi#Analysis",
          "name": ":BioassayAnalysis"
        },
        {
          "id": "https://w3id.org/emi#BiologicalSex",
          "parent": "root",
          "name": ":BiologicalSex"
        },
        {
          "id": "https://w3id.org/emi#Blank",
          "parent": "root",
          "name": ":Blank"
        },
        {
          "id": "https://w3id.org/emi#CSpair",
          "parent": "https://w3id.org/emi#SpectralPair",
          "name": ":CSpair"
        },
        {
          "id": "https://w3id.org/emi#Chemical",
          "parent": "https://w3id.org/emi#ChemicalEntity",
          "name": ":Chemical"
        },
        {
          "id": "https://w3id.org/emi#ChemicalEntity",
          "parent": "root",
          "name": ":ChemicalEntity"
        },
        {
          "id": "https://w3id.org/emi#ChemicalStructure",
          "parent": "https://w3id.org/emi#ChemicalEntity",
          "name": ":ChemicalStructure"
        },
        {
          "id": "https://w3id.org/emi#ChemicalTaxon",
          "parent": "https://w3id.org/emi#ChemicalEntity",
          "name": ":ChemicalTaxon"
        },
        {
          "id": "https://w3id.org/emi#ChemicalTaxonAnnotation",
          "parent": "https://w3id.org/emi#SpectrumAnnotation",
          "name": ":ChemicalTaxonAnnotation"
        },
        {
          "id": "https://w3id.org/emi#ComputationalAnalysis",
          "parent": "https://w3id.org/emi#Analysis",
          "name": ":ComputationalAnalysis"
        },
        {
          "id": "https://w3id.org/emi#ContinousTrait",
          "parent": "https://w3id.org/emi#Trait",
          "name": ":ContinousTrait"
        },
        {
          "id": "https://w3id.org/emi#DevelopmentalStage",
          "parent": "root",
          "name": ":DevelopmentalStage"
        },
        {
          "id": "https://w3id.org/emi#DiscreteTrait",
          "parent": "https://w3id.org/emi#Trait",
          "name": ":DiscreteTrait"
        },
        {
          "id": "https://w3id.org/emi#ExtractSample",
          "parent": "root",
          "name": ":ExtractSample"
        },
        {
          "id": "https://w3id.org/emi#FBMNComponent",
          "parent": "root",
          "name": ":FBMNComponent"
        },
        {
          "id": "https://w3id.org/emi#GNPSConsensusSpectrum",
          "parent": "https://w3id.org/emi#MS2Spectrum",
          "name": ":GNPSConsensusSpectrum"
        },
        {
          "id": "https://w3id.org/emi#Habitat",
          "parent": "root",
          "name": ":Habitat"
        },
        {
          "id": "https://w3id.org/emi#InChIKey",
          "parent": "https://w3id.org/emi#ChemicalStructure",
          "name": ":InChIKey"
        },
        {
          "id": "https://w3id.org/emi#InChIKey2D",
          "parent": "https://w3id.org/emi#ChemicalStructure",
          "name": ":InChIKey2D"
        },
        {
          "id": "https://w3id.org/emi#InformationSource",
          "parent": "root",
          "name": ":InformationSource"
        },
        {
          "id": "https://w3id.org/emi#Interaction",
          "parent": "root",
          "name": ":Interaction"
        },
        {
          "id": "https://w3id.org/emi#InteractionType",
          "parent": "root",
          "name": ":InteractionType"
        },
        {
          "id": "https://w3id.org/emi#LCMSAnalysis",
          "parent": "https://w3id.org/emi#Analysis",
          "name": ":LCMSAnalysis"
        },
        {
          "id": "https://w3id.org/emi#LCMSAnalysisNeg",
          "parent": "https://w3id.org/emi#LCMSAnalysis",
          "name": ":LCMSAnalysisNeg"
        },
        {
          "id": "https://w3id.org/emi#LCMSAnalysisPos",
          "parent": "https://w3id.org/emi#LCMSAnalysis",
          "name": ":LCMSAnalysisPos"
        },
        {
          "id": "https://w3id.org/emi#LCMSFeature",
          "parent": "https://w3id.org/emi#MS2Spectrum",
          "name": ":LCMSFeature"
        },
        {
          "id": "https://w3id.org/emi#LCMSFeatureSet",
          "parent": "root",
          "name": ":LCMSFeatureSet"
        },
        {
          "id": "https://w3id.org/emi#LFpair",
          "parent": "https://w3id.org/emi#SpectralPair",
          "name": ":LFpair"
        },
        {
          "id": "https://w3id.org/emi#Locality",
          "parent": "root",
          "name": ":Locality"
        },
        {
          "id": "https://w3id.org/emi#MS2Spectrum",
          "parent": "root",
          "name": ":MS2Spectrum"
        },
        {
          "id": "https://w3id.org/emi#NonTrait",
          "parent": "root",
          "name": ":NonTrait"
        },
        {
          "id": "https://w3id.org/emi#Organism",
          "parent": "https://w3id.org/emi#System",
          "name": ":Organism"
        },
        {
          "id": "https://w3id.org/emi#OrganismGroup",
          "parent": "root",
          "name": ":OrganismGroup"
        },
        {
          "id": "https://w3id.org/emi#PhysiologicalStage",
          "parent": "root",
          "name": ":PhysiologicalStage"
        },
        {
          "id": "https://w3id.org/emi#QCSample",
          "parent": "root",
          "name": ":QCSample"
        },
        {
          "id": "https://w3id.org/emi#RawMaterial",
          "parent": "root",
          "name": ":RawMaterial"
        },
        {
          "id": "https://w3id.org/emi#Spec2VecDoc",
          "parent": "root",
          "name": ":Spec2VecDoc"
        },
        {
          "id": "https://w3id.org/emi#SpectralPair",
          "parent": "root",
          "name": ":SpectralPair"
        },
        {
          "id": "https://w3id.org/emi#SpectrumAnnotation",
          "parent": "root",
          "name": ":SpectrumAnnotation"
        },
        {
          "id": "https://w3id.org/emi#StructuralAnnotation",
          "parent": "https://w3id.org/emi#SpectrumAnnotation",
          "name": ":StructuralAnnotation"
        },
        {
          "id": "https://w3id.org/emi#System",
          "parent": "root",
          "name": ":System"
        },
        {
          "id": "https://w3id.org/emi#Taxon",
          "parent": "root",
          "name": ":Taxon"
        },
        {
          "id": "https://w3id.org/emi#Trait",
          "parent": "root",
          "name": ":Trait"
        },
        {
          "id": "https://w3id.org/emi#WDChemicalStructure",
          "parent": "https://w3id.org/emi#Chemical",
          "name": ":WDChemicalStructure"
        }
      ],
      "transform": [
        {
          "type": "stratify",
          "key": "id",
          "parentKey": "parent"
        },
        {
          "type": "tree",
          "method": {
            "signal": "layout"
          },
          "size": [
            1,
            1
          ],
          "as": [
            "alpha",
            "beta",
            "depth",
            "children"
          ]
        },
        {
          "type": "formula",
          "expr": "(rotate + extent * datum.alpha + 270) % 360",
          "as": "angle"
        },
        {
          "type": "formula",
          "expr": "inrange(datum.angle, [90, 270])",
          "as": "leftside"
        },
        {
          "type": "formula",
          "expr": "originX + radius * datum.beta * cos(PI * datum.angle / 180)",
          "as": "x"
        },
        {
          "type": "formula",
          "expr": "originY + radius * datum.beta * sin(PI * datum.angle / 180)",
          "as": "y"
        }
      ]
    },
    {
      "name": "leaves",
      "source": "tree",
      "transform": [
        {
          "type": "filter",
          "expr": "!datum.children && datum.id !== 'root'"
        }
      ]
    },
    {
      "name": "dependencies",
      "values": [
        {
          "source": "https://w3id.org/emi#CSpair",
          "target": "https://w3id.org/emi#GNPSConsensusSpectrum",
          "edge_class": ":hasPairMember"
        },
        {
          "source": "https://w3id.org/emi#CSpair",
          "target": "https://w3id.org/emi#LCMSFeature",
          "edge_class": ":hasPairMember"
        },
        {
          "source": "https://w3id.org/emi#GNPSConsensusSpectrum",
          "target": "https://w3id.org/emi#ChemicalTaxonAnnotation",
          "edge_class": ":hasAnnotation"
        },
        {
          "source": "https://w3id.org/emi#GNPSConsensusSpectrum",
          "target": "https://w3id.org/emi#StructuralAnnotation",
          "edge_class": ":hasAnnotation"
        },
        {
          "source": "https://w3id.org/emi#InChIKey",
          "target": "https://w3id.org/emi#InChIKey2D",
          "edge_class": ":hasInChIKey2D"
        },
        {
          "source": "https://w3id.org/emi#InChIKey2D",
          "target": "https://w3id.org/emi#InChIKey",
          "edge_class": ":isInChIKey2DOf"
        },
        {
          "source": "https://w3id.org/emi#Interaction",
          "target": "https://w3id.org/emi#Habitat",
          "edge_class": ":hasHabitat"
        },
        {
          "source": "https://w3id.org/emi#LCMSAnalysisNeg",
          "target": "https://w3id.org/emi#LCMSFeatureSet",
          "edge_class": ":hasLCMSFeatureSet"
        },
        {
          "source": "https://w3id.org/emi#LCMSAnalysisPos",
          "target": "https://w3id.org/emi#LCMSFeatureSet",
          "edge_class": ":hasLCMSFeatureSet"
        },
        {
          "source": "https://w3id.org/emi#LCMSFeature",
          "target": "https://w3id.org/emi#ChemicalTaxonAnnotation",
          "edge_class": ":hasAnnotation"
        },
        {
          "source": "https://w3id.org/emi#LCMSFeature",
          "target": "https://w3id.org/emi#GNPSConsensusSpectrum",
          "edge_class": ":hasConsensusSpectrum"
        },
        {
          "source": "https://w3id.org/emi#LCMSFeature",
          "target": "https://w3id.org/emi#Spec2VecDoc",
          "edge_class": ":hasSpec2VecDoc"
        },
        {
          "source": "https://w3id.org/emi#LCMSFeature",
          "target": "https://w3id.org/emi#StructuralAnnotation",
          "edge_class": ":hasAnnotation"
        },
        {
          "source": "https://w3id.org/emi#LCMSFeatureSet",
          "target": "https://w3id.org/emi#LCMSFeature",
          "edge_class": ":hasLCMSFeature"
        },
        {
          "source": "https://w3id.org/emi#LFpair",
          "target": "https://w3id.org/emi#GNPSConsensusSpectrum",
          "edge_class": ":hasPairMember"
        },
        {
          "source": "https://w3id.org/emi#LFpair",
          "target": "https://w3id.org/emi#LCMSFeature",
          "edge_class": ":hasFirstMember"
        },
        {
          "source": "https://w3id.org/emi#StructuralAnnotation",
          "target": "https://w3id.org/emi#InChIKey",
          "edge_class": ":hasChemicalStructure"
        },
        {
          "source": "https://w3id.org/emi#StructuralAnnotation",
          "target": "https://w3id.org/emi#InChIKey2D",
          "edge_class": ":hasChemicalStructure"
        }
      ],
      "transform": [
        {
          "type": "formula",
          "expr": "treePath('tree', datum.source, datum.target)",
          "as": "treepath",
          "initonly": true
        },
        {
          "type": "filter",
          "expr": "datum.treepath && length(datum.treepath) > 1"
        }
      ]
    },
    {
      "name": "selected",
      "source": "dependencies",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.source === active || datum.target === active"
        }
      ]
    }
  ],
  "scales": [
    {
      "name": "edgeColor",
      "type": "ordinal",
      "domain": {
        "data": "dependencies",
        "field": "edge_class"
      },
      "range": {
        "scheme": "category20"
      }
    }
  ],
  "legends": [
    {
      "stroke": "edgeColor",
      "title": "Edge class",
      "orient": "right"
    }
  ],
  "marks": [
    {
      "type": "text",
      "from": {
        "data": "leaves"
      },
      "encode": {
        "enter": {
          "text": {
            "field": "name"
          },
          "baseline": {
            "value": "middle"
          }
        },
        "update": {
          "x": {
            "field": "x"
          },
          "y": {
            "field": "y"
          },
          "dx": {
            "signal": "textOffset * (datum.leftside ? -1 : 1)"
          },
          "angle": {
            "signal": "datum.leftside ? datum.angle - 180 : datum.angle"
          },
          "align": {
            "signal": "datum.leftside ? 'right' : 'left'"
          },
          "fontSize": {
            "signal": "textSize"
          },
          "fontWeight": [
            {
              "test": "indata('selected', 'source', datum.id)",
              "value": "bold"
            },
            {
              "test": "indata('selected', 'target', datum.id)",
              "value": "bold"
            },
            {
              "value": null
            }
          ],
          "fill": [
            {
              "test": "datum.id === active",
              "value": "black"
            },
            {
              "test": "indata('selected', 'source', datum.id)",
              "signal": "colorIn"
            },
            {
              "test": "indata('selected', 'target', datum.id)",
              "signal": "colorOut"
            },
            {
              "value": "#111827"
            }
          ]
        }
      }
    },
    {
      "type": "group",
      "from": {
        "facet": {
          "name": "path",
          "data": "dependencies",
          "field": "treepath"
        }
      },
      "marks": [
        {
          "type": "line",
          "interactive": false,
          "from": {
            "data": "path"
          },
          "encode": {
            "enter": {
              "interpolate": {
                "value": "bundle"
              },
              "strokeWidth": {
                "value": 1.2
              }
            },
            "update": {
              "stroke": [
                {
                  "test": "parent.source === active",
                  "signal": "colorOut"
                },
                {
                  "test": "parent.target === active",
                  "signal": "colorIn"
                },
                {
                  "scale": "edgeColor",
                  "field": "parent.edge_class"
                }
              ],
              "strokeOpacity": [
                {
                  "test": "parent.source === active || parent.target === active",
                  "value": 1
                },
                {
                  "value": 0.28
                }
              ],
              "tension": {
                "signal": "tension"
              },
              "x": {
                "field": "x"
              },
              "y": {
                "field": "y"
              }
            }
          }
        }
      ]
    }
  ]
}